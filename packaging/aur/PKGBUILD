# Maintainer: David Almeida <david.almeidac@gmail.com>
#
# AUR package for sealed-env Studio (-bin).
#
# Installs the pre-built x86_64 .deb produced by the release workflow into
# an Arch system. This is the recommended path for Arch users — building
# Tauri 2 + WebKitGTK from source on Arch is non-trivial and brittle.
#
# Submit / update via:
#   cd ~/aur/sealed-env-studio-bin
#   makepkg --printsrcinfo > .SRCINFO
#   git add PKGBUILD .SRCINFO && git commit -m "upgpkg: sealed-env-studio-bin X.Y.Z-1"
#   git push aur
#
# Or via the publish workflow (`.github/workflows/aur-publish.yml`) which
# regenerates pkgver + checksums + .SRCINFO on every `studio-v*` tag and
# pushes to ssh+git://aur@aur.archlinux.org/sealed-env-studio-bin.git

pkgname=sealed-env-studio-bin
_pkgname=sealed-env-studio
pkgver=0.1.0
pkgrel=1
pkgdesc="Desktop GUI for sealed-env — encrypted .env file manager (Tauri)"
arch=('x86_64')
url="https://github.com/davidalmeidac/sealed-env-studio"
license=('MIT')

# Tauri 2 with WebKitGTK 4.1 runtime + Sigillum design system fonts.
depends=(
  'webkit2gtk-4.1'
  'gtk3'
  'libayatana-appindicator'
  'librsvg'
)

# Mark conflict with hypothetical source build so users don't double-install.
provides=("$_pkgname")
conflicts=("$_pkgname")

# Pull the matching .deb from the GitHub Release.
source=("$pkgname-$pkgver.deb::https://github.com/davidalmeidac/sealed-env-studio/releases/download/studio-v$pkgver/${_pkgname}_${pkgver}_amd64.deb")

# SHA256 of the .deb. Regenerated by aur-publish.yml — when bumping pkgver
# manually, run `updpkgsums` to refresh.
sha256sums=('SKIP')

package() {
  # The Tauri .deb is laid out as a standard Debian package. Extract its
  # data.tar.* into $pkgdir, then move things into place.
  cd "$srcdir"

  # `bsdtar` from libarchive can unpack ar archives in one step.
  bsdtar -xf "$pkgname-$pkgver.deb"

  # The .deb contains data.tar.gz (or .xz / .zst depending on build).
  # Find whichever variant Tauri emitted and extract into $pkgdir.
  for ext in gz xz zst; do
    if [ -f "data.tar.$ext" ]; then
      bsdtar -xf "data.tar.$ext" -C "$pkgdir/"
      break
    fi
  done

  # Drop the .deb control metadata — Arch doesn't use it.
  rm -f "$pkgdir/control" "$pkgdir/md5sums" "$pkgdir/postinst" \
        "$pkgdir/prerm" 2>/dev/null || true
}
